/* General Look */
body { font-family: 'Arial', sans-serif; background: #f4f4f4; margin: 0; padding: 0; }
.card { background: white; border-radius: 10px; padding: 15px; text-align: center; border: 1px solid #ddd; }
.price { color: red; font-weight: bold; }
.btn { background: #ff0000; color: white; padding: 10px 20px; border: none; border-radius: 5px; cursor: pointer; }

/* Grid Layout (Diamond packages ke liye) */
.grid-container { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; padding: 10px; }
