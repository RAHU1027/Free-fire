body { font-family: sans-serif; background-color: #f4f4f4; margin: 0; }
header { background: white; padding: 15px; border-bottom: 2px solid red; }
.banner { background: #eee; padding: 20px; text-align: center; margin: 10px; border-radius: 10px; }
.login-container { background: white; margin: 10px; padding: 20px; border-radius: 8px; }
.step { color: red; font-weight: bold; margin-bottom: 10px; }
.input-group { display: flex; gap: 5px; }
input { flex: 1; padding: 10px; border: 1px solid #ccc; }
button { background: red; color: white; border: none; padding: 10px 20px; }
.transaction { background: white; margin: 10px; padding: 15px; border-left: 5px solid green; }
