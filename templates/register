<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Register</title>
</head>
<body class="bg-gray-950 text-white flex items-center justify-center min-h-screen">
    <div class="bg-gray-900 p-8 rounded-2xl w-full max-w-sm border border-gray-800">
        <h2 class="text-2xl font-bold mb-6 text-center">Create Account</h2>
        <form action="/register" method="POST" class="space-y-4">
            <input type="email" name="email" placeholder="Email" required class="w-full p-3 bg-gray-800 rounded-lg outline-none">
            <input type="password" name="password" placeholder="Password" required class="w-full p-3 bg-gray-800 rounded-lg outline-none">
            <button class="w-full bg-blue-600 p-3 rounded-lg font-bold">Register</button>
        </form>
        <p class="mt-4 text-sm text-center">Have an account? <a href="/login" class="text-blue-400">Login</a></p>
    </div>
</body>
</html>
